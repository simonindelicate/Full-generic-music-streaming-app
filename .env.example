# ── Core ──────────────────────────────────────────────────────────
# The public URL your server is reachable at (no trailing slash).
# Used to build absolute URLs for uploaded files and the catalogue feed.
APP_BASE_URL=http://localhost:3000

# Port the Node.js server listens on (default: 3000)
PORT=3000

# ── Storage ────────────────────────────────────────────────────────
# Local directory where uploaded files and metadata JSON are stored.
# Must be a persistent path — mount a Docker volume here.
# Defaults to ./storage relative to the project root.
STORAGE_ROOT=./storage

# ── Admin ─────────────────────────────────────────────────────────
# Generate any random secret string — this is your admin password.
ADMIN_API_TOKEN=

# ── Catalogue discovery (optional) ────────────────────────────────
# Set to true to allow your catalogue to appear in public discovery APIs.
DISCOVERY_OPT_IN=false

# ── PayPal payments (optional, for gated/paid content) ────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
